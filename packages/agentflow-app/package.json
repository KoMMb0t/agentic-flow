{
  "name": "agentflow-desktop",
  "version": "2.0.0",
  "description": "AgentFlow - Unified Multi-Platform KI-Agenten Orchestrierung mit Agent Router, Skill-Marktplatz, GitHub Dashboard und mehr",
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json && electron .",
    "build": "tsc -p tsconfig.main.json && vite build",
    "build:check": "tsc --noEmit && tsc -p tsconfig.main.json --noEmit",
    "start": "electron .",
    "package": "npm run build && electron-builder"
  },
  "author": "KoMMb0t",
  "license": "MIT",
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "zustand": "^5.0.2",
    "lucide-react": "^0.460.0",
    "date-fns": "^4.1.0",
    "uuid": "^11.0.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  },
  "build": {
    "appId": "com.kommb0t.agentflow",
    "productName": "AgentFlow",
    "files": [
      "dist/**/*",
      "data/**/*",
      "public/**/*"
    ],
    "directories": {
      "output": "release"
    }
  }
}

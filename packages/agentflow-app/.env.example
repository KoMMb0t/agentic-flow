# AgentFlow Desktop - Environment Variables
# Kopiere diese Datei zu .env und trage deine Werte ein
# WICHTIG: .env wird NIEMALS committed (in .gitignore)

# ── KI-Dienste ───────────────────────────────────────────────

# Anthropic Claude API
# Erstelle einen Key unter: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI / ChatGPT
# Erstelle einen Key unter: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# OpenRouter (200+ Modelle)
# Erstelle einen Key unter: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# ── Code-Hosting ─────────────────────────────────────────────

# GitHub Personal Access Token
# Erstelle ein Token unter: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...
GITHUB_USERNAME=KoMMb0t

# GitLab Personal Access Token (optional)
# Erstelle ein Token unter: https://gitlab.com/-/profile/personal_access_tokens
GITLAB_TOKEN=glpat-...

# ── Kommunikation ─────────────────────────────────────────────

# Slack Bot Token
# Erstelle eine App unter: https://api.slack.com/apps
SLACK_TOKEN=xoxb-...

# ── Projektmanagement ────────────────────────────────────────

# ClickUp API Token
# Erstelle einen Token unter: https://app.clickup.com/settings/apps
CLICKUP_TOKEN=pk_...

# ── Datei-Speicherung ────────────────────────────────────────

# Google API Key (Drive API)
# Erstelle Credentials unter: https://console.cloud.google.com/apis/credentials
GOOGLE_API_KEY=AIza...
